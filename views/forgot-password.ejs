<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f8fafc; }
  </style>
</head>
<body class="bg-white text-slate-900">

  <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200/80 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-800 via-blue-700 to-slate-800 bg-clip-text text-transparent">
          XSpaceFinance
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-sm font-medium text-slate-500 hover:text-slate-900">Home</a>
          <a href="/about" class="text-sm font-medium text-slate-500 hover:text-slate-900">About</a>
          <a href="/plans" class="text-sm font-medium text-slate-500 hover:text-slate-900">Plans</a>
          <a href="/calculator" class="text-sm font-medium text-slate-500 hover:text-slate-900">Calculator</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="/signin" class="text-sm font-medium text-slate-600 hover:text-slate-900">Sign In</a>
          <a href="/register" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-800">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <section class="min-h-[calc(100vh-8rem)] flex items-center justify-center py-12 bg-slate-50/60">
    <div class="w-full max-w-[480px] px-4">
      <div class="text-center mb-7">
        <h1 class="text-[22px] font-semibold text-slate-900 tracking-tight">Reset your password</h1>
        <p class="mt-1.5 text-[13px] text-slate-400">Enter the email address associated with your account and we'll send a link to reset your password.</p>
      </div>

      <div class="bg-white border border-slate-200/80 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 sm:px-8 py-7 sm:py-8">
          
          <% if (error) { %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm text-center">
              <%= error %>
            </div>
          <% } %>
          
          <% if (message) { %>
            <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-600 text-sm text-center">
              <%= message %>
            </div>
          <% } %>
          
          <form method="POST" action="/forgot-password">
            <div class="mb-6">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Email Address</label>
              <input type="email" name="email" required autofocus
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 placeholder:text-slate-300 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400 transition"
                     placeholder="name@company.com">
            </div>

            <button type="submit" class="w-full text-[13px] font-medium text-white bg-slate-800 hover:bg-slate-900 rounded-lg px-4 py-2.5 transition-colors">
              Send Reset Link
            </button>
          </form>
        </div>
      </div>

      <!-- What happens next section -->
      <div class="mt-8 bg-white border border-slate-200/80 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 py-5">
          <h3 class="text-sm font-semibold text-slate-800 mb-3">What happens next</h3>
          <div class="space-y-3">
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-slate-100 text-slate-600 text-xs flex items-center justify-center flex-shrink-0 mt-0.5">1</div>
              <p class="text-[12px] text-slate-500">We'll send a secure reset link to your email</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-slate-100 text-slate-600 text-xs flex items-center justify-center flex-shrink-0 mt-0.5">2</div>
              <p class="text-[12px] text-slate-500">Click the link within 60 minutes to proceed</p>
            </div>
            <div class="flex items-start gap-3">
              <div class="w-5 h-5 rounded-full bg-slate-100 text-slate-600 text-xs flex items-center justify-center flex-shrink-0 mt-0.5">3</div>
              <p class="text-[12px] text-slate-500">Choose a new password for your account</p>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6 text-center">
        <p class="text-[12px] text-slate-400">
          Remember your password?
          <a href="/signin" class="font-medium text-slate-600 hover:text-slate-800">Back to sign in</a>
        </p>
      </div>
    </div>
  </section>

  <footer class="bg-slate-950 text-slate-400 py-8 mt-12">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2026 XSpaceFinance. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>