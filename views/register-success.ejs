<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Account Created - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body class="bg-white text-slate-900">

  <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200/80 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-800 via-blue-700 to-slate-800 bg-clip-text text-transparent">
          XSpaceFinance
        </a>
        <div class="flex items-center gap-3">
          <a href="/signin" class="text-sm font-medium text-slate-600 hover:text-slate-900">Sign In</a>
          <a href="/register" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-800">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 bg-slate-50/60">
    <div class="w-full max-w-[420px] px-4">

      <div class="text-center mb-7">
        <div class="mx-auto w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center mb-4">
          <svg class="w-6 h-6 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/>
          </svg>
        </div>
        <h1 class="text-[22px] font-semibold text-slate-900 tracking-tight">Account Created!</h1>
        <p class="mt-1.5 text-[13px] text-slate-400 max-w-[340px] mx-auto leading-relaxed">
          <%= typeof message !== 'undefined' ? message : 'Your account has been created successfully.' %>
        </p>
      </div>

      <div class="bg-white border border-slate-200/80 rounded-xl shadow-sm">
        <div class="px-6 sm:px-8 py-7 sm:py-8">
          <div class="bg-blue-50 border border-blue-100 rounded-lg p-4 mb-6">
            <p class="text-[13px] text-blue-700 text-center">
              We've sent a verification link to <strong><%= typeof email !== 'undefined' ? email : 'your email' %></strong>.<br>
              Please check your inbox to verify your account.
            </p>
          </div>
          <a href="/signin" class="block w-full text-center text-[13px] font-medium text-white bg-slate-800 hover:bg-slate-900 rounded-lg px-4 py-2.5 transition-colors">
            Go to Sign In
          </a>
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-slate-950 text-slate-400 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2026 XSpaceFinance. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>