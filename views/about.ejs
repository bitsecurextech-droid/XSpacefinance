  <script>
    // Live compliance feed rotating messages
    const complianceMessages = [
      "Data encryption verified",
      "Quarterly audit completed",
      "KYC sanctions list screened",
      "AML transaction monitoring",
      "Compliance audit passed",
      "GDPR compliance verified",
      "Security protocols active"
    ];
    
    let messageIndex = 0;
    const feedText = document.getElementById('feedText');
    const feedContainer = document.getElementById('complianceFeed');
    
    setInterval(() => {
      messageIndex = (messageIndex + 1) % complianceMessages.length;
      if (feedContainer) {
        feedContainer.classList.remove('animate-slide-in');
        void feedContainer.offsetWidth; // Force reflow
        feedContainer.classList.add('animate-slide-in');
      }
      if (feedText) {
        feedText.textContent = complianceMessages[messageIndex];
      }
    }, 4000);
  </script>
