<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sign In - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f8fafc; }
  </style>
</head>
<body class="bg-white text-slate-900">

  <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200/80 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-800 via-blue-700 to-slate-800 bg-clip-text text-transparent">
          XSpaceFinance
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-sm font-medium text-slate-500 hover:text-slate-900">Home</a>
          <a href="/about" class="text-sm font-medium text-slate-500 hover:text-slate-900">About</a>
          <a href="/plans" class="text-sm font-medium text-slate-500 hover:text-slate-900">Plans</a>
          <a href="/calculator" class="text-sm font-medium text-slate-500 hover:text-slate-900">Calculator</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="/signin" class="text-sm font-medium text-slate-600 hover:text-slate-900">Sign In</a>
          <a href="/register" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-800">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 bg-slate-50/60">
    <div class="w-full max-w-[420px] px-4">
      <div class="text-center mb-7">
        <h1 class="text-[22px] font-semibold text-slate-900 tracking-tight">Sign in to your account</h1>
        <p class="mt-1.5 text-[13px] text-slate-400">Choose your preferred sign-in method</p>
      </div>

      <div class="bg-white border border-slate-200/80 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 sm:px-8 py-7 sm:py-8">
          <!-- Flash messages -->
          <% if (messages && messages.error) { %>
            <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm"><%= messages.error %></div>
          <% } %>
          <% if (messages && messages.success) { %>
            <div class="mb-4 p-3 bg-green-50 border border-green-200 rounded-lg text-green-600 text-sm"><%= messages.success %></div>
          <% } %>

          <form method="POST" action="/signin">
            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Email Address</label>
              <input type="email" name="email" required autofocus
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 placeholder:text-slate-300 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400 transition"
                     placeholder="name@company.com">
            </div>

            <div class="mb-4">
              <div class="flex items-center justify-between mb-1.5">
                <label class="text-[11px] font-medium text-slate-500 uppercase tracking-wider">Password</label>
                <a href="/forgot-password" class="text-[11px] font-medium text-slate-400 hover:text-slate-600">Forgot password?</a>
              </div>
              <input type="password" name="password" required
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 placeholder:text-slate-300 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400 transition"
                     placeholder="Enter your password">
            </div>

            <div class="mb-6">
              <label class="flex items-center cursor-pointer">
                <input type="checkbox" name="remember" class="w-3.5 h-3.5 rounded border-slate-300 text-slate-800">
                <span class="ml-2 text-[12px] text-slate-500 select-none">Keep me signed in</span>
              </label>
            </div>

            <button type="submit" class="w-full text-[13px] font-medium text-white bg-slate-800 hover:bg-slate-900 rounded-lg px-4 py-2.5 transition-colors">
              Sign In
            </button>
          </form>
        </div>

        <div class="px-6 sm:px-8 py-4 border-t border-slate-100 text-center">
          <p class="text-[12px] text-slate-400">
            Don't have an account?
            <a href="/register" class="font-medium text-slate-600 hover:text-slate-800">Create an account</a>
          </p>
        </div>
      </div>

      <div class="mt-6 flex items-center justify-center gap-1.5">
        <svg class="w-3 h-3 text-slate-300" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"/></svg>
        <p class="text-[10px] text-slate-300">Secured with 256-bit encryption</p>
      </div>
    </div>
  </section>

  <footer class="bg-slate-950 text-slate-400 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2026 XSpaceFinance. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>