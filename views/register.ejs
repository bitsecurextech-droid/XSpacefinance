<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Account - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f8fafc; }
  </style>
</head>
<body class="bg-white text-slate-900">

  <nav class="bg-white/95 backdrop-blur-sm border-b border-slate-200/80 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16">
        <a href="/" class="text-xl font-extrabold tracking-tight bg-gradient-to-r from-slate-800 via-blue-700 to-slate-800 bg-clip-text text-transparent">
          XSpaceFinance
        </a>
        <div class="hidden md:flex items-center gap-6">
          <a href="/" class="text-sm font-medium text-slate-500 hover:text-slate-900">Home</a>
          <a href="/about" class="text-sm font-medium text-slate-500 hover:text-slate-900">About</a>
          <a href="/plans" class="text-sm font-medium text-slate-500 hover:text-slate-900">Plans</a>
          <a href="/calculator" class="text-sm font-medium text-slate-500 hover:text-slate-900">Calculator</a>
        </div>
        <div class="flex items-center gap-3">
          <a href="/signin" class="text-sm font-medium text-slate-600 hover:text-slate-900">Sign In</a>
          <a href="/register" class="bg-slate-900 text-white px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-slate-800">Get Started</a>
        </div>
      </div>
    </div>
  </nav>

  <section class="min-h-[calc(100vh-4rem)] flex items-center justify-center py-12 bg-slate-50/60">
    <div class="w-full max-w-[480px] px-4">
      <div class="text-center mb-7">
        <h1 class="text-[22px] font-semibold text-slate-900 tracking-tight">Create an account</h1>
        <p class="mt-1.5 text-[13px] text-slate-400">Join XSpaceFinance today</p>
      </div>

      <div class="bg-white border border-slate-200/80 rounded-xl shadow-sm overflow-hidden">
        <div class="px-6 sm:px-8 py-7 sm:py-8">
          <form method="POST" action="/register">
            <input type="hidden" name="_csrf" value="<%= typeof csrfToken !== 'undefined' ? csrfToken : '' %>">

            <div class="grid grid-cols-2 gap-3 mb-4">
              <div>
                <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">First Name</label>
                <input type="text" name="first_name" required
                       class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400">
              </div>
              <div>
                <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Last Name</label>
                <input type="text" name="last_name" required
                       class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400">
              </div>
            </div>

            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Email Address</label>
              <input type="email" name="email" required
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 placeholder:text-slate-300 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400"
                     placeholder="name@company.com">
            </div>

            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Account Region</label>
              <select name="country" class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400">
                <option value="US">United States (USD)</option>
                <option value="UK">United Kingdom (GBP)</option>
                <option value="CA">Canada (CAD)</option>
              </select>
              <p class="text-[11px] text-slate-400 mt-1">Determines your account currency. Cannot be changed later.</p>
            </div>

            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Password</label>
              <input type="password" name="password" required minlength="8"
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400"
                     placeholder="Min. 8 characters">
            </div>

            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Confirm Password</label>
              <input type="password" name="confirm" required
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400"
                     placeholder="Re-enter password">
            </div>

            <div class="mb-4">
              <label class="block text-[11px] font-medium text-slate-500 uppercase tracking-wider mb-1.5">Referral Code (Optional)</label>
              <input type="text" name="referral" placeholder="Enter referral code"
                     class="w-full text-[13px] border border-slate-200/80 rounded-lg px-3.5 py-2.5 text-slate-800 focus:ring-2 focus:ring-slate-900/10 focus:border-slate-400">
            </div>

            <% if (typeof error !== 'undefined' && error) { %>
              <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-600 text-sm text-center">
                <%= error %>
              </div>
            <% } %>

            <p class="text-xs text-slate-500 mb-4">By creating an account you agree to our <a href="/terms" class="text-blue-600 hover:underline">Terms of Service</a> and <a href="/privacy" class="text-blue-600 hover:underline">Privacy Policy</a>.</p>

            <button type="submit" class="w-full text-[13px] font-medium text-white bg-slate-800 hover:bg-slate-900 rounded-lg px-4 py-2.5 transition-colors">
              Create Account
            </button>
          </form>
        </div>

        <div class="px-6 sm:px-8 py-4 border-t border-slate-100 text-center">
          <p class="text-[12px] text-slate-400">
            Already have an account?
            <a href="/signin" class="font-medium text-slate-600 hover:text-slate-800">Sign in</a>
          </p>
        </div>
      </div>
    </div>
  </section>

  <footer class="bg-slate-950 text-slate-400 py-8">
    <div class="max-w-7xl mx-auto px-4 text-center text-sm">
      <p>&copy; 2026 XSpaceFinance. All rights reserved.</p>
    </div>
  </footer>
</body>
</html>