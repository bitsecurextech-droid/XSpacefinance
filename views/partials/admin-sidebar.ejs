<button id="sidebar-toggle" class="lg:hidden fixed bottom-4 right-4 z-50 p-3 bg-purple-600 rounded-full shadow-lg">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
</button>
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden lg:hidden"></div>
<aside id="admin-sidebar" class="fixed left-0 top-0 bottom-0 w-64 bg-slate-900 border-r border-slate-800 z-40 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 overflow-y-auto">
  <div class="p-6">
    <a href="/admin" class="text-xl font-bold block mb-8">XSpace<span class="text-purple-500">Admin</span></a>
    <div class="mb-6 p-3 bg-slate-800 rounded-lg">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 bg-purple-500/20 rounded-full flex items-center justify-center">
          <span class="text-purple-500 font-bold"><%= admin?.first_name?.charAt(0) || 'A' %></span>
        </div>
        <div class="flex-1">
          <p class="font-semibold text-sm"><%= admin?.first_name %> <%= admin?.last_name %></p>
          <p class="text-xs text-slate-400">Administrator</p>
        </div>
      </div>
    </div>
    <nav class="space-y-1">
      <a href="/admin" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'dashboard' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
        <span>Dashboard</span>
      </a>

      <a href="/admin/users" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'users' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z"/></svg>
        <span>Users</span>
      </a>

      <a href="/admin/deposits" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'deposits' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        <span>Deposits</span>
      </a>

      <a href="/admin/withdrawals" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'withdrawals' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/></svg>
        <span>Withdrawals</span>
      </a>

      <a href="/admin/plans" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'plans' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/></svg>
        <span>Investment Plans</span>
      </a>

      <a href="/admin/kyc" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'kyc' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        <span>KYC Review</span>
      </a>

      <a href="/admin/files" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'files' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z"/></svg>
        <span>Uploaded Files</span>
      </a>

      <a href="/admin/logs" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'logs' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
        <span>Activity Logs</span>
      </a>

      <a href="/admin/settings" class="flex items-center gap-3 px-3 py-2 rounded-lg hover:bg-slate-800 transition text-slate-300 <%= currentPage === 'settings' ? 'bg-slate-800 text-white' : '' %>">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
        <span>Settings</span>
      </a>

      <div class="pt-4 mt-4 border-t border-slate-800">
        <a href="/dashboard" class="flex items-center gap-3 px-3 py-2 rounded-lg text-slate-400 hover:bg-slate-800 transition">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg>
          <span>User Dashboard</span>
        </a>
        <a href="/logout" class="flex items-center gap-3 px-3 py-2 rounded-lg text-red-400 hover:bg-red-500/10 transition mt-2">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
          <span>Logout</span>
        </a>
      </div>
    </nav>
  </div>
</aside>
<script>
  const sidebar = document.getElementById('admin-sidebar');
  const overlay = document.getElementById('sidebar-overlay');
  const toggleBtn = document.getElementById('sidebar-toggle');
  function openSidebar() { sidebar.classList.remove('-translate-x-full'); overlay.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
  function closeSidebar() { sidebar.classList.add('-translate-x-full'); overlay.classList.add('hidden'); document.body.style.overflow = ''; }
  if (toggleBtn) toggleBtn.addEventListener('click', openSidebar);
  if (overlay) overlay.addEventListener('click', closeSidebar);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !sidebar.classList.contains('-translate-x-full')) closeSidebar(); });
</script>