<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Active Plans - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .sidebar-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; padding-left: 12px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .stat-card { transition: all 0.2s; background: white; border-radius: 16px; border: 1px solid #e2e8f0; padding: 16px; }
    .progress-bar { transition: width 0.5s ease; }
  </style>
</head>
<body>

<div class="flex">
  <!-- SIDEBAR -->
  <%- include('../partials/complete-sidebar') %>

  <!-- MAIN CONTENT -->
  <div class="flex-1 lg:ml-64">
    <!-- TOPBAR (partial) -->
    <%- include('../partials/topbar') %>

    <!-- Page Content -->
    <div class="p-6">
      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-6">
        <div class="stat-card">
          <p class="text-sm text-slate-500">Total Active Plans</p>
          <p class="text-2xl font-bold text-slate-800 mt-1"><%= activePlans ? activePlans.length : 0 %></p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-slate-500">Total Invested</p>
          <p class="text-2xl font-bold text-slate-800 mt-1">$<%= activePlans ? activePlans.reduce((sum, p) => sum + parseFloat(p.amount), 0).toLocaleString() : 0 %></p>
        </div>
        <div class="stat-card">
          <p class="text-sm text-slate-500">Expected Returns</p>
          <p class="text-2xl font-bold text-emerald-600 mt-1">$<%= activePlans ? activePlans.reduce((sum, p) => sum + parseFloat(p.amount) * 1.2, 0).toLocaleString() : 0 %></p>
        </div>
      </div>

      <!-- Active Plans List -->
      <% if (activePlans && activePlans.length > 0) { %>
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
          <% for (var i = 0; i < activePlans.length; i++) { 
            var plan = activePlans[i];
          %>
            <div class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm hover:shadow-md transition">
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-bold text-lg text-slate-800">Investment #<%= plan.id %></h3>
                <span class="px-3 py-1 bg-green-100 text-green-700 text-xs rounded-full">Active</span>
              </div>
              <div class="space-y-2">
                <p class="text-slate-600">Amount: <span class="font-semibold">$<%= parseFloat(plan.amount).toLocaleString() %></span></p>
                <p class="text-slate-600">Status: <span class="capitalize"><%= plan.status %></span></p>
                <p class="text-slate-500 text-sm">Started: <%= new Date(plan.created_at).toLocaleDateString() %></p>
                <% if (plan.end_date) { %>
                  <p class="text-slate-500 text-sm">Maturity: <%= new Date(plan.end_date).toLocaleDateString() %></p>
                <% } %>
              </div>
            </div>
          <% } %>
        </div>
      <% } else { %>
        <div class="bg-white rounded-xl border border-slate-200 p-12 text-center">
          <svg class="w-16 h-16 mx-auto mb-4 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
          </svg>
          <h3 class="text-xl font-semibold text-slate-800 mb-2">No Active Plans</h3>
          <p class="text-slate-500 mb-6">You don't have any active investment plans at the moment.</p>
          <a href="/dashboard/new-investment" class="inline-block px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition">Start Investing →</a>
        </div>
      <% } %>
    </div>
  </div>
</div>

<!-- User dropdown script is already inside topbar partial, so no need to duplicate -->
</body>
</html>