<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Notifications - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; background: #f1f5f9; }
    .sidebar-link { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: 12px; font-size: 14px; font-weight: 500; transition: all 0.2s; color: #64748b; }
    .sidebar-link:hover { background: #f1f5f9; color: #1e293b; }
    .sidebar-link.active { background: #e0f2fe; color: #0284c7; }
    .sidebar-icon { width: 20px; height: 20px; }
    .sidebar-section-label { font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px; color: #94a3b8; margin-bottom: 8px; padding-left: 12px; }
    .topbar { background: white; border-bottom: 1px solid #e2e8f0; padding: 12px 24px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 40; }
    .notification-item { transition: all 0.2s; }
    .notification-item:hover { background: #f8fafc; }
    .notification-unread { background: #eff6ff; border-left: 3px solid #3b82f6; }
  </style>
</head>
<body>

<div class="flex">
  <%- include('../partials/complete-sidebar') %>

  <div class="flex-1 lg:ml-64">
    <!-- TOPBAR (partial) -->
    <%- include('../partials/topbar') %>

    <!-- Notifications Content -->
    <div class="p-6">
      <div class="bg-white rounded-xl border border-slate-200 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-200 flex justify-between items-center">
          <div>
            <h2 class="font-semibold text-slate-800">All Notifications</h2>
            <p class="text-xs text-slate-500 mt-0.5">Recent account activities and alerts</p>
          </div>
          <button id="markAllRead" class="text-xs text-blue-600 hover:text-blue-700">Mark all as read</button>
        </div>

        <div class="divide-y divide-slate-100">
          <% if (notifications && notifications.length > 0) { %>
            <% notifications.forEach(function(notification) { %>
              <div class="notification-item <%= notification.is_read ? '' : 'notification-unread' %> p-4">
                <div class="flex gap-3">
                  <!-- Icon based on type (can be customised) -->
                  <div class="flex-shrink-0">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center 
                      <% if (notification.type === 'deposit') { %>bg-emerald-100<% } 
                      else if (notification.type === 'investment') { %>bg-purple-100<% } 
                      else if (notification.type === 'withdrawal') { %>bg-orange-100<% } 
                      else if (notification.type === 'login') { %>bg-blue-100<% } 
                      else if (notification.type === 'kyc') { %>bg-yellow-100<% } 
                      else { %>bg-slate-100<% } %>">
                      <% if (notification.type === 'deposit') { %>
                        <svg class="w-5 h-5 text-emerald-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/>
                        </svg>
                      <% } else if (notification.type === 'investment') { %>
                        <svg class="w-5 h-5 text-purple-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
                        </svg>
                      <% } else if (notification.type === 'withdrawal') { %>
                        <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5m-13.5-9L12 3m0 0 4.5 4.5M12 3v13.5"/>
                        </svg>
                      <% } else if (notification.type === 'login') { %>
                        <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
                        </svg>
                      <% } else if (notification.type === 'kyc') { %>
                        <svg class="w-5 h-5 text-yellow-600" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M9 12.75 11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 0 1-1.043 3.296 3.745 3.745 0 0 1-3.296 1.043A3.745 3.745 0 0 1 12 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 0 1-3.296-1.043 3.745 3.745 0 0 1-1.043-3.296A3.745 3.745 0 0 1 3 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 0 1 1.043-3.296 3.746 3.746 0 0 1 3.296-1.043A3.746 3.746 0 0 1 12 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 0 1 3.296 1.043 3.746 3.746 0 0 1 1.043 3.296A3.745 3.745 0 0 1 21 12Z"/>
                        </svg>
                      <% } else { %>
                        <svg class="w-5 h-5 text-slate-500" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                          <path d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                        </svg>
                      <% } %>
                    </div>
                  </div>
                  <div class="flex-1">
                    <div class="flex items-center gap-2">
                      <span class="font-medium text-slate-800"><%= notification.title %></span>
                      <% if (!notification.is_read) { %>
                        <span class="px-2 py-0.5 bg-red-100 text-red-600 text-[10px] rounded-full">Unread</span>
                      <% } %>
                    </div>
                    <p class="text-sm text-slate-500 mt-0.5"><%= notification.message %></p>
                    <p class="text-xs text-slate-400 mt-1"><%= new Date(notification.created_at).toLocaleString() %></p>
                  </div>
                </div>
              </div>
            <% }); %>
          <% } else { %>
            <div class="p-12 text-center">
              <svg class="w-16 h-16 mx-auto mb-4 text-slate-300" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
                <path d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
              </svg>
              <p class="text-slate-500">No notifications yet.</p>
            </div>
          <% } %>
        </div>

        <% if (notifications && notifications.length > 0) { %>
          <div class="px-6 py-4 border-t border-slate-200 text-center">
            <button id="loadMore" class="text-sm text-blue-600 hover:text-blue-700">Load more notifications →</button>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>

<script>
  // ===== Mark all as read =====
  document.getElementById('markAllRead')?.addEventListener('click', async () => {
    try {
      const res = await fetch('/dashboard/notifications/mark-all-read', { method: 'POST' });
      if (res.ok) {
        location.reload();
      } else {
        alert('Failed to mark all as read.');
      }
    } catch (e) {
      console.error(e);
    }
  });

  // ===== Load more (pagination) – placeholder =====
  document.getElementById('loadMore')?.addEventListener('click', () => {
    alert('Pagination not implemented yet – you can fetch next page here.');
  });
</script>
</body>
</html>