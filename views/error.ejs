<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Error' %> - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
  </style>
</head>
<body class="bg-slate-950 text-white">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="mb-8">
        <svg class="w-24 h-24 mx-auto text-slate-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path>
        </svg>
      </div>
      <h1 class="text-4xl font-bold mb-4">
        <% if (typeof error !== 'undefined' && error.status === 404) { %>
          404 - Page Not Found
        <% } else if (typeof error !== 'undefined' && error.status === 403) { %>
          403 - Access Denied
        <% } else { %>
          Something Went Wrong
        <% } %>
      </h1>
      <p class="text-slate-400 mb-8">
        <%= typeof message !== 'undefined' ? message : 'An unexpected error occurred. Please try again later.' %>
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 rounded-lg font-semibold transition">Go Home</a>
        <button onclick="window.history.back()" class="px-6 py-3 border border-slate-700 hover:bg-slate-800 rounded-lg font-semibold transition">Go Back</button>
      </div>
    </div>
  </div>
</body>
</html>