    <script>
        // Mobile menu
        document.getElementById('mobile-menu-btn')?.addEventListener('click', function() {
            var menu = document.getElementById('mobile-menu');
            var openIcon = this.querySelector('.icon-open');
            var closeIcon = this.querySelector('.icon-close');
            menu.classList.toggle('hidden');
            openIcon.classList.toggle('hidden');
            closeIcon.classList.toggle('hidden');
        });

        // ===== PHONE SCREEN ROTATION =====
        (function() {
            const screens = document.querySelectorAll('.screen-slide');
            const dots = document.querySelectorAll('.phone-dot');
            let currentIndex = 0;
            const total = screens.length;
            let interval;

            function goTo(index) {
                if (index === currentIndex) return;
                // Remove active from all
                screens.forEach((s, i) => {
                    s.classList.remove('active');
                    s.classList.add('exit');
                });
                dots.forEach(d => d.classList.remove('active'));

                // Show target
                setTimeout(() => {
                    screens.forEach(s => s.classList.remove('exit'));
                    screens[index].classList.add('active');
                    dots[index].classList.add('active');
                    currentIndex = index;
                }, 50);
            }

            function nextScreen() {
                const next = (currentIndex + 1) % total;
                goTo(next);
            }

            // Dot click handlers
            dots.forEach((dot, idx) => {
                dot.addEventListener('click', function() {
                    clearInterval(interval);
                    goTo(idx);
                    interval = setInterval(nextScreen, 5000);
                });
            });

            // Start rotation
            screens.forEach((s, i) => {
                if (i === 0) s.classList.add('active');
                else s.classList.add('exit');
            });
            dots[0].classList.add('active');

            interval = setInterval(nextScreen, 5000);
        })();

        // ===== CALCULATOR =====
        document.addEventListener('DOMContentLoaded', function() {
            var slider = document.getElementById('calc-amount');
            var amountDisplay = document.getElementById('calc-amount-display');
            var investedEl = document.getElementById('calc-invested');
            var returnEl = document.getElementById('calc-return');
            var profitEl = document.getElementById('calc-profit');
            var buttons = document.querySelectorAll('.plan-select-btn');

            if (!slider || !buttons.length) return;

            var rate = parseFloat(buttons[0].dataset.rate) || 1;
            var duration = parseFloat(buttons[0].dataset.duration) || 1;

            function fmt(n) {
                return '$' + Math.round(n).toLocaleString('en-US');
            }

            function calc() {
                var p = parseInt(slider.value);
                var r = rate / 100;
                var n = duration;
                var total = p * Math.pow(1 + r, n);
                var profit = total - p;

                amountDisplay.textContent = fmt(p);
                investedEl.textContent = fmt(p);
                returnEl.textContent = fmt(total);
                profitEl.textContent = '+' + fmt(profit);
            }

            slider.addEventListener('input', calc);

            buttons.forEach(function(btn) {
                btn.addEventListener('click', function() {
                    buttons.forEach(function(b) {
                        b.classList.remove('bg-slate-900', 'text-white', 'border-slate-900');
                        b.classList.add('bg-white', 'text-slate-600', 'border-slate-200');
                    });
                    this.classList.remove('bg-white', 'text-slate-600', 'border-slate-200');
                    this.classList.add('bg-slate-900', 'text-white', 'border-slate-900');

                    rate = parseFloat(this.dataset.rate);
                    duration = parseFloat(this.dataset.duration);
                    calc();
                });
            });

            calc();
        });
    </script>

