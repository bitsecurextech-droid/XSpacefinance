  <!-- Support Chat Button -->
  <button onclick="alert('Support: support@xspacefinance.com')" class="fixed bottom-6 right-6 z-50 size-14 rounded-full bg-blue-600 text-white grid place-items-center shadow-xl shadow-blue-600/30 hover:scale-105 transition">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2.992 16.342a2 2 0 0 1 .094 1.167l-1.065 3.29a1 1 0 0 0 1.236 1.168l3.413-.998a2 2 0 0 1 1.099.092 10 10 0 1 0-4.777-4.719"/></svg>
  </button>

  <script>
    // Screen rotation
    let currentScreen = 1;
    const screens = {
      1: document.getElementById('screen1'),
      2: document.getElementById('screen2'),
      3: document.getElementById('screen3'),
      4: document.getElementById('screen4'),
      5: document.getElementById('screen5')
    };
    
    function showScreen(screenNum) {
      if (currentScreen === screenNum) return;
      if (screens[currentScreen]) screens[currentScreen].style.opacity = '0';
      setTimeout(() => { if (screens[screenNum]) screens[screenNum].style.opacity = '1'; }, 50);
      currentScreen = screenNum;
    }
    
    let screenOrder = [1, 2, 3, 4, 5];
    let screenIndex = 0;
    setInterval(() => {
      screenIndex = (screenIndex + 1) % screenOrder.length;
      showScreen(screenOrder[screenIndex]);
    }, 6000);
    
    // Animate numbers on Screen 1
    let balanceValue = 24883.60;
    let inv1Value = 3649;
    let inv2Value = 683;
    let dailyRet = 9.70;
    let inv1Progress = 66;
    let inv2Progress = 33;
    let direction = 1;
    
    setInterval(() => {
      const change = (Math.random() * 20 + 5) * direction;
      balanceValue += change;
      const balanceEl = document.getElementById('balanceValue');
      balanceEl.classList.add('number-update');
      balanceEl.textContent = '$' + balanceValue.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      setTimeout(() => balanceEl.classList.remove('number-update'), 300);
      
      inv1Value += change * 0.3;
      const inv1El = document.getElementById('inv1Amount');
      inv1El.classList.add('number-update');
      inv1El.textContent = '+$' + Math.floor(inv1Value).toLocaleString();
      setTimeout(() => inv1El.classList.remove('number-update'), 300);
      
      inv2Value += change * 0.1;
      const inv2El = document.getElementById('inv2Amount');
      inv2El.classList.add('number-update');
      inv2El.textContent = '+$' + Math.floor(inv2Value).toLocaleString();
      setTimeout(() => inv2El.classList.remove('number-update'), 300);
      
      dailyRet += change * 0.02;
      const dailyEl = document.getElementById('dailyReturn');
      dailyEl.classList.add('number-update');
      dailyEl.textContent = '+$' + dailyRet.toFixed(2);
      setTimeout(() => dailyEl.classList.remove('number-update'), 300);
      
      inv1Progress += (Math.random() * 2 - 1) * 0.5;
      inv1Progress = Math.min(95, Math.max(5, inv1Progress));
      document.getElementById('inv1Progress').style.width = inv1Progress + '%';
      
      inv2Progress += (Math.random() * 2 - 1) * 0.8;
      inv2Progress = Math.min(95, Math.max(5, inv2Progress));
      document.getElementById('inv2Progress').style.width = inv2Progress + '%';
      
      const chartPath = document.getElementById('chartLine');
      if (chartPath) chartPath.setAttribute('d', `M0,35 Q25,25 50,18 T100,${5 + Math.random() * 15}`);
      
      if (Math.random() < 0.1) direction *= -1;
    }, 4000);
    
    // Animate monthly returns on Screen 5
    let monthValues = [175, 181, 187, 194, 201, 208];
    setInterval(() => {
      for (let i = 1; i <= 6; i++) {
        const change = (Math.random() * 10 - 5) * direction;
        monthValues[i-1] += change;
        monthValues[i-1] = Math.max(50, Math.min(500, monthValues[i-1]));
        const el = document.getElementById('month' + i);
        if (el) {
          el.classList.add('number-update');
          el.textContent = '+$' + Math.floor(monthValues[i-1]);
          setTimeout(() => el.classList.remove('number-update'), 300);
        }
      }
      const currentValEl = document.getElementById('currentValue');
      if (currentValEl) {
        const totalValue = monthValues.reduce((a,b) => a + b, 5000);
        currentValEl.classList.add('number-update');
        currentValEl.textContent = '$' + Math.floor(totalValue).toLocaleString();
        setTimeout(() => currentValEl.classList.remove('number-update'), 300);
      }
    }, 5000);
    
    // Calculator functionality
    const calcAmount = document.getElementById('calcAmount');
    const calcPlan = document.getElementById('calcPlan');
    const calcAmountDisplay = document.getElementById('calcAmountDisplay');
    const projectedReturnSpan = document.getElementById('projectedReturn');
    const netGainSpan = document.getElementById('netGain');
    
    function updateCalculator() {
      const amount = parseFloat(calcAmount.value);
      const months = parseInt(calcPlan.value);
      let roi = 0;
      if (months === 12) roi = 2.0;
      else if (months === 24) roi = 3.5;
      else roi = 5.0;
      
      calcAmountDisplay.textContent = amount.toLocaleString();
      const totalReturn = amount * Math.pow(1 + (roi/100), months);
      const netGain = totalReturn - amount;
      
      projectedReturnSpan.textContent = '$' + totalReturn.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
      netGainSpan.textContent = (netGain >= 0 ? '+' : '') + '$' + netGain.toFixed(2).replace(/\B(?=(\d{3})+(?!\d))/g, ',');
    }
    
    if (calcAmount && calcPlan) {
      calcAmount.addEventListener('input', updateCalculator);
      calcPlan.addEventListener('change', updateCalculator);
      updateCalculator();
    }
  </script>
</body>
</html>