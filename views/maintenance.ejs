<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Maintenance - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <style>
    body { font-family: 'Inter', sans-serif; }
    @keyframes spin {
      to { transform: rotate(360deg); }
    }
    .animate-spin-slow {
      animation: spin 3s linear infinite;
    }
  </style>
</head>
<body class="bg-slate-950 text-white">
  <div class="min-h-screen flex items-center justify-center px-4">
    <div class="text-center max-w-md">
      <div class="mb-8">
        <svg class="w-24 h-24 mx-auto text-blue-500 animate-spin-slow" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"></path>
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"></path>
        </svg>
      </div>
      <h1 class="text-4xl font-bold mb-4 font-display">Under Maintenance</h1>
      <p class="text-slate-400 mb-4">
        We're currently performing scheduled maintenance to improve your experience.
      </p>
      <p class="text-slate-500 text-sm mb-8">
        Please check back in a few minutes.
      </p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a href="/" class="px-6 py-3 bg-blue-600 hover:bg-blue-700 rounded-lg font-semibold transition">
          Refresh Page
        </a>
        <a href="/contact" class="px-6 py-3 border border-slate-700 hover:bg-slate-800 rounded-lg font-semibold transition">
          Contact Support
        </a>
      </div>
      <div class="mt-8 pt-8 border-t border-slate-800">
        <p class="text-xs text-slate-600">
          &copy; <%= new Date().getFullYear() %> XSpaceFinance. All rights reserved.
        </p>
      </div>
    </div>
  </div>
  <script>
    // Auto-refresh every 30 seconds to check if maintenance is done
    setTimeout(() => {
      window.location.reload();
    }, 30000);
  </script>
</body>
</html>