<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Manage Plans - XSpaceFinance</title><script src="https://cdn.tailwindcss.com"></script><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"></head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  <%- include('../partials/admin-sidebar') %>
  <div class="lg:ml-72 min-h-screen">
    <div class="bg-slate-800/50 border-b border-slate-700 px-6 py-4"><h1 class="text-2xl font-bold bg-gradient-to-r from-white to-blue-400 bg-clip-text text-transparent">Investment Plans</h1><p class="text-slate-400 text-sm">Create and manage investment plans</p></div>
    <div class="p-6">
      <button onclick="document.getElementById('createModal').classList.remove('hidden')" class="mb-4 px-4 py-2 bg-green-600 rounded-lg hover:bg-green-700">+ Create New Plan</button>
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6"><% plans.forEach(function(p) { %><div class="bg-slate-800 border border-slate-700 rounded-xl p-6"><div class="flex justify-between items-start mb-4"><div><h3 class="font-bold text-lg"><%= p.name %></h3><p class="text-xs text-slate-400">ID: <%= p.id %></p></div><span class="px-2 py-1 rounded text-xs <%= p.is_active ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400' %>"><%= p.is_active ? 'Active' : 'Inactive' %></span></div><div class="space-y-2 mb-4"><div class="flex justify-between"><span class="text-slate-400">Duration</span><span class="font-semibold"><%= p.duration_days %> days</span></div><div class="flex justify-between"><span class="text-slate-400">ROI</span><span class="font-semibold text-green-400"><%= p.roi_percent %>%/month</span></div><div class="flex justify-between"><span class="text-slate-400">Range</span><span class="font-semibold">$<%= p.min_amount.toLocaleString() %> - $<%= p.max_amount.toLocaleString() %></span></div></div><div class="flex gap-2"><button onclick='editPlan(<%= JSON.stringify(p) %>)' class="flex-1 px-3 py-2 bg-blue-600 rounded-lg text-sm">Edit</button><button onclick='deletePlan(<%= p.id %>)' class="px-3 py-2 bg-red-600 rounded-lg text-sm">Delete</button></div></div><% }); %></div>
    </div>
  </div>
  <div id="createModal" class="fixed inset-0 bg-black/70 z-50 hidden items-center justify-center"><div class="bg-slate-800 rounded-xl max-w-md w-full p-6"><h2 class="text-xl font-bold mb-4">Create New Plan</h2><form method="POST" action="/admin/plans/create"><div class="space-y-3"><input type="text" name="name" placeholder="Plan Name" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="duration_days" placeholder="Duration (days)" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" step="0.01" name="roi_percent" placeholder="Monthly ROI %" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="min_amount" placeholder="Min Amount" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="max_amount" placeholder="Max Amount" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><label class="flex items-center gap-2"><input type="checkbox" name="is_active" checked class="w-4 h-4"> Active</label><div class="flex gap-2"><button type="submit" class="flex-1 px-4 py-2 bg-green-600 rounded-lg">Create</button><button type="button" onclick="document.getElementById('createModal').classList.add('hidden')" class="flex-1 px-4 py-2 bg-slate-600 rounded-lg">Cancel</button></div></div></form></div></div>
  <div id="editModal" class="fixed inset-0 bg-black/70 z-50 hidden items-center justify-center"><div class="bg-slate-800 rounded-xl max-w-md w-full p-6"><h2 class="text-xl font-bold mb-4">Edit Plan</h2><form id="editForm" method="POST" action="/admin/plans/update"><input type="hidden" name="id" id="editId"><div class="space-y-3"><input type="text" name="name" id="editName" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="duration_days" id="editDays" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" step="0.01" name="roi_percent" id="editRoi" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="min_amount" id="editMin" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><input type="number" name="max_amount" id="editMax" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2" required><label class="flex items-center gap-2"><input type="checkbox" name="is_active" id="editActive" class="w-4 h-4"> Active</label><div class="flex gap-2"><button type="submit" class="flex-1 px-4 py-2 bg-blue-600 rounded-lg">Update</button><button type="button" onclick="document.getElementById('editModal').classList.add('hidden')" class="flex-1 px-4 py-2 bg-slate-600 rounded-lg">Cancel</button></div></div></form></div></div>
  <script>function editPlan(p) { document.getElementById('editId').value = p.id; document.getElementById('editName').value = p.name; document.getElementById('editDays').value = p.duration_days; document.getElementById('editRoi').value = p.roi_percent; document.getElementById('editMin').value = p.min_amount; document.getElementById('editMax').value = p.max_amount; document.getElementById('editActive').checked = p.is_active === 1; document.getElementById('editModal').classList.remove('hidden'); } async function deletePlan(id) { if(confirm('Delete this plan?')) { const res = await fetch(`/admin/plans/${id}/delete`, { method: 'POST', headers: { 'Content-Type': 'application/x-www-form-urlencoded' } }); if(res.ok) location.reload(); else alert('Failed to delete plan'); } }</script>
</body>
</html>