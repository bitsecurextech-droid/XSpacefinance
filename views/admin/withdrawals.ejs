<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Manage Withdrawals - XSpaceFinance</title><script src="https://cdn.tailwindcss.com"></script><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"></head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  <%- include('../partials/admin-sidebar') %>
  <div class="lg:ml-72 min-h-screen">
    <div class="bg-slate-800/50 border-b border-slate-700 px-6 py-4"><h1 class="text-2xl font-bold bg-gradient-to-r from-white to-blue-400 bg-clip-text text-transparent">Manage Withdrawals</h1><p class="text-slate-400 text-sm">Review and process user withdrawal requests</p></div>
    <div class="p-6">
      <div class="flex gap-2 mb-4"><a href="/admin/withdrawals?status=pending" class="px-4 py-2 rounded-lg bg-yellow-500/20 text-yellow-400">Pending</a><a href="/admin/withdrawals?status=completed" class="px-4 py-2 rounded-lg bg-green-500/20 text-green-400">Completed</a><a href="/admin/withdrawals?status=rejected" class="px-4 py-2 rounded-lg bg-red-500/20 text-red-400">Rejected</a><a href="/admin/withdrawals?status=all" class="px-4 py-2 rounded-lg bg-slate-700 text-slate-300">All</a></div>
      <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden"><div class="overflow-x-auto"><table class="w-full"><thead class="bg-slate-700/50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">User</th><th class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase">Amount</th><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Method</th><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Destination</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Status</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Date</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Actions</th></tr></thead><tbody><% withdrawals.forEach(function(w) { %><tr class="border-t border-slate-700 hover:bg-slate-700/30 transition"><td class="px-6 py-4"><%= w.first_name %> <%= w.last_name %><br><span class="text-xs text-slate-400"><%= w.email %></span></td><td class="px-6 py-4 text-right font-mono"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(w.amount) %></td><td class="px-6 py-4"><%= w.method || 'Crypto' %></td><td class="px-6 py-4 font-mono text-xs truncate max-w-[200px]"><%= w.address %></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= w.status === 'completed' ? 'bg-green-500/20 text-green-400' : w.status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-red-500/20 text-red-400' %>"><%= w.status %></span></td><td class="px-6 py-4 text-center text-sm"><%= new Date(w.created_at).toLocaleDateString() %></td><td class="px-6 py-4 text-center"><% if(w.status === 'pending') { %><form method="POST" action="/admin/withdrawal/<%= w.id %>/approve" class="inline"><button class="px-3 py-1 bg-green-600 rounded-lg text-sm mr-1">Approve</button></form><form method="POST" action="/admin/withdrawal/<%= w.id %>/reject" class="inline"><button class="px-3 py-1 bg-red-600 rounded-lg text-sm">Reject</button></form><% } else { %>—<% } %></td></tr><% }); %></tbody></table></div></div>
    </div>
  </div>
</body>
</html>