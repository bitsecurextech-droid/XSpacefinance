<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Dashboard - XSpaceFinance</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>
    * { font-family: 'Inter', sans-serif; }
    .sidebar-item { transition: all 0.2s ease; }
    .sidebar-item:hover { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
    .sidebar-item.active { background: rgba(59, 130, 246, 0.15); color: #3b82f6; border-left: 3px solid #3b82f6; }
    .stat-card { transition: transform 0.2s ease, box-shadow 0.2s ease; }
    .stat-card:hover { transform: translateY(-3px); box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.3); }
  </style>
</head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  
  <!-- Mobile Toggle -->
  <button id="sidebar-toggle" class="lg:hidden fixed top-4 left-4 z-50 p-2 bg-blue-600 rounded-lg shadow-lg">
    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
  </button>
  <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-40 hidden lg:hidden"></div>

  <!-- Sidebar -->
  <aside id="sidebar" class="fixed left-0 top-0 bottom-0 w-72 bg-slate-900 border-r border-slate-700 z-50 transform -translate-x-full lg:translate-x-0 transition-transform duration-300 overflow-y-auto">
    <div class="p-6">
      <div class="flex items-center gap-3 mb-8 pb-4 border-b border-slate-700">
        <div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-xl flex items-center justify-center"><span class="text-white font-bold text-xl">X</span></div>
        <div><h1 class="text-xl font-bold">XSpace<span class="text-blue-500">Admin</span></h1><p class="text-xs text-slate-400">Investment Platform</p></div>
      </div>
      
      <div class="mb-6 p-4 bg-slate-800/50 rounded-xl border border-slate-700">
        <div class="flex items-center gap-3">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center"><span class="text-white font-bold text-lg"><%= admin?.first_name?.charAt(0) || 'A' %></span></div>
          <div class="flex-1"><p class="font-semibold text-white"><%= admin?.first_name %> <%= admin?.last_name %></p><p class="text-xs text-slate-400"><%= admin?.email %></p><span class="inline-block mt-1 px-2 py-0.5 bg-blue-500/20 text-blue-400 text-[10px] rounded-full">Super Admin</span></div>
        </div>
      </div>
      
      <nav class="space-y-1">
        <a href="/admin" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><span>Dashboard</span></a>
        <a href="/admin/users" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg><span>Users</span></a>
        <a href="/admin/deposits" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg><span>Deposits</span></a>
        <a href="/admin/withdrawals" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg><span>Withdrawals</span></a>
        <a href="/admin/plans" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg><span>Investment Plans</span></a>
        <a href="/admin/kyc" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg><span>KYC Review</span></a>
        <a href="/admin/logs" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg><span>Activity Logs</span></a>
        <a href="/admin/settings" class="sidebar-item flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-300"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg><span>Settings</span></a>
      </nav>
      
      <div class="my-6 border-t border-slate-700"></div>
      
      <nav class="space-y-1">
        <a href="/dashboard" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-slate-400 hover:bg-slate-800 transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/></svg><span>User Dashboard</span></a>
        <a href="/logout" class="flex items-center gap-3 px-4 py-2.5 rounded-lg text-red-400 hover:bg-red-500/10 transition"><svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg><span>Logout</span></a>
      </nav>
    </div>
  </aside>

  <!-- Main Content -->
  <div class="lg:ml-72 min-h-screen">
    <div class="bg-slate-800/50 border-b border-slate-700 px-6 py-4 sticky top-0 z-30 backdrop-blur-sm">
      <div class="flex justify-between items-center"><div><h1 class="text-2xl font-bold bg-gradient-to-r from-white to-blue-400 bg-clip-text text-transparent">Admin Dashboard</h1><p class="text-slate-400 text-sm">Platform overview and management</p></div><div class="flex items-center gap-4"><div class="hidden md:flex items-center gap-2 px-3 py-1.5 bg-slate-700 rounded-lg"><span class="w-2 h-2 bg-green-500 rounded-full animate-pulse"></span><span class="text-xs text-slate-300">System Online</span></div><div class="w-10 h-10 bg-gradient-to-br from-blue-500 to-purple-600 rounded-full flex items-center justify-center"><span class="text-white font-bold"><%= admin?.first_name?.charAt(0) || 'A' %></span></div></div></div>
    </div>

    <div class="p-6">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="stat-card bg-gradient-to-br from-slate-800 to-slate-800/50 rounded-xl p-6 border border-slate-700"><div class="flex items-center justify-between mb-4"><div class="p-2 bg-blue-500/20 rounded-lg"><svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"/></svg></div><span class="text-2xl font-bold text-white"><%= stats.total_users %></span></div><p class="text-slate-400 text-sm">Total Users</p></div>
        <div class="stat-card bg-gradient-to-br from-slate-800 to-slate-800/50 rounded-xl p-6 border border-slate-700"><div class="flex items-center justify-between mb-4"><div class="p-2 bg-yellow-500/20 rounded-lg"><svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M7 16a4 4 0 01-.88-7.903A5 5 0 1115.9 6L16 6a5 5 0 011 9.9M15 13l-3-3m0 0l-3 3m3-3v12"/></svg></div><div class="text-right"><span class="text-2xl font-bold text-white"><%= stats.pending_deposits_count %></span><p class="text-xs text-slate-400"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(stats.pending_deposits_total) %></p></div></div><p class="text-slate-400 text-sm">Pending Deposits</p></div>
        <div class="stat-card bg-gradient-to-br from-slate-800 to-slate-800/50 rounded-xl p-6 border border-slate-700"><div class="flex items-center justify-between mb-4"><div class="p-2 bg-red-500/20 rounded-lg"><svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg></div><div class="text-right"><span class="text-2xl font-bold text-white"><%= stats.pending_withdrawals_count %></span><p class="text-xs text-slate-400"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(stats.pending_withdrawals_total) %></p></div></div><p class="text-slate-400 text-sm">Pending Withdrawals</p></div>
        <div class="stat-card bg-gradient-to-br from-slate-800 to-slate-800/50 rounded-xl p-6 border border-slate-700"><div class="flex items-center justify-between mb-4"><div class="p-2 bg-purple-500/20 rounded-lg"><svg class="w-6 h-6 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/></svg></div><span class="text-2xl font-bold text-white"><%= stats.pending_kyc %></span></div><p class="text-slate-400 text-sm">Pending KYC</p></div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
        <div class="bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-xl p-5 border border-slate-700"><p class="text-slate-400 text-sm">Total Active Investments</p><p class="text-2xl font-bold text-white"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(stats.total_invested) %></p></div>
        <div class="bg-gradient-to-r from-slate-800 to-slate-800/50 rounded-xl p-5 border border-slate-700"><p class="text-slate-400 text-sm">Total ROI Paid</p><p class="text-2xl font-bold text-green-400"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(stats.total_paid) %></p></div>
      </div>
      
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-slate-800 rounded-xl border border-slate-700 p-6"><h3 class="font-bold mb-4">Revenue Overview</h3><canvas id="revenueChart" height="200"></canvas></div>
        <div class="bg-slate-800 rounded-xl border border-slate-700 p-6"><h3 class="font-bold mb-4">User Growth</h3><canvas id="userChart" height="200"></canvas></div>
      </div>
      
      <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden mb-8">
        <div class="px-6 py-4 border-b border-slate-700 flex justify-between items-center"><h2 class="font-bold text-lg">Recent Users</h2><a href="/admin/users" class="text-sm text-blue-400 hover:text-blue-300">View All →</a></div>
        <div class="overflow-x-auto"><table class="w-full"><thead class="bg-slate-700/50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">User</th><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Email</th><th class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase">Balance</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">KYC</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Status</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase"></th></tr></thead><tbody><% recent_users.forEach(function(u) { %><tr class="border-t border-slate-700 hover:bg-slate-700/30 transition"><td class="px-6 py-4 font-medium"><%= u.first_name %> <%= u.last_name %></td><td class="px-6 py-4 text-slate-300"><%= u.email %></td><td class="px-6 py-4 text-right font-mono"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(u.balance) %></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= u.kyc_status === 'approved' ? 'bg-green-500/20 text-green-400' : u.kyc_status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-slate-600 text-slate-400' %>"><%= u.kyc_status || 'unverified' %></span></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= u.is_banned ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400' %>"><%= u.is_banned ? 'Banned' : 'Active' %></span></td><td class="px-6 py-4 text-center"><a href="/admin/user/<%= u.id %>" class="text-blue-400 hover:text-blue-300 text-sm">Manage</a></td></tr><% }); %></tbody></table></div>
      </div>
      
      <div class="bg-slate-800 rounded-xl border border-slate-700 overflow-hidden">
        <div class="px-6 py-4 border-b border-slate-700 flex justify-between items-center"><h2 class="font-bold text-lg">Recent Deposits</h2><a href="/admin/deposits" class="text-sm text-blue-400 hover:text-blue-300">View All →</a></div>
        <div class="overflow-x-auto"><table class="w-full"><thead class="bg-slate-700/50"><tr><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">User</th><th class="px-6 py-3 text-right text-xs font-medium text-slate-400 uppercase">Amount</th><th class="px-6 py-3 text-left text-xs font-medium text-slate-400 uppercase">Method</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Status</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Date</th><th class="px-6 py-3 text-center text-xs font-medium text-slate-400 uppercase">Actions</th></tr></thead><tbody><% recent_deposits.forEach(function(d) { %><tr class="border-t border-slate-700 hover:bg-slate-700/30 transition"><td class="px-6 py-4"><%= d.first_name %> <%= d.last_name %></td><td class="px-6 py-4 text-right font-mono"><%= new Intl.NumberFormat('en-US', { style: 'currency', currency: 'USD' }).format(d.amount) %></td><td class="px-6 py-4"><%= d.method || 'Crypto' %></td><td class="px-6 py-4 text-center"><span class="px-2 py-1 rounded text-xs <%= d.status === 'approved' ? 'bg-green-500/20 text-green-400' : d.status === 'pending' ? 'bg-yellow-500/20 text-yellow-400' : 'bg-red-500/20 text-red-400' %>"><%= d.status %></span></td><td class="px-6 py-4 text-center text-sm"><%= new Date(d.created_at).toLocaleDateString() %></td><td class="px-6 py-4 text-center"><% if(d.status === 'pending') { %><form method="POST" action="/admin/deposit/<%= d.id %>/approve" class="inline"><button class="px-2 py-1 bg-green-600 rounded text-xs mr-1">Approve</button></form><form method="POST" action="/admin/deposit/<%= d.id %>/reject" class="inline"><button class="px-2 py-1 bg-red-600 rounded text-xs">Reject</button></form><% } else { %>—<% } %></td></tr><% }); %></tbody></table></div>
      </div>
    </div>
  </div>

  <script>
    const sidebar = document.getElementById('sidebar'); const overlay = document.getElementById('sidebar-overlay'); const toggleBtn = document.getElementById('sidebar-toggle');
    function openSidebar() { sidebar.classList.remove('-translate-x-full'); overlay.classList.remove('hidden'); document.body.style.overflow = 'hidden'; }
    function closeSidebar() { sidebar.classList.add('-translate-x-full'); overlay.classList.add('hidden'); document.body.style.overflow = ''; }
    if (toggleBtn) toggleBtn.addEventListener('click', openSidebar);
    if (overlay) overlay.addEventListener('click', closeSidebar);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !sidebar.classList.contains('-translate-x-full')) closeSidebar(); });
    
    // Sample chart data - replace with real data from your backend
    const ctx1 = document.getElementById('revenueChart')?.getContext('2d');
    if(ctx1) new Chart(ctx1, { type: 'line', data: { labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'], datasets: [{ label: 'Revenue', data: [12500, 15000, 18200, 21000, 25800, 31200], borderColor: '#3b82f6', backgroundColor: 'rgba(59,130,246,0.1)', fill: true }] }, options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#94a3b8' } } } } });
    const ctx2 = document.getElementById('userChart')?.getContext('2d');
    if(ctx2) new Chart(ctx2, { type: 'bar', data: { labels: ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun'], datasets: [{ label: 'New Users', data: [45, 52, 68, 74, 89, 112], backgroundColor: '#8b5cf6', borderRadius: 8 }] }, options: { responsive: true, maintainAspectRatio: true, plugins: { legend: { labels: { color: '#94a3b8' } } } } });
  </script>
</body>
</html>