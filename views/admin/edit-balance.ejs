<%- include('../partials/header') %>
<body class="bg-white">
<div class="flex">
  <%- include('sidebar') %>
  <div class="flex-1 flex flex-col min-h-screen">
    <%- include('topbar', { title: 'Edit User Balance' }) %>
    <main class="flex-1 p-6">
      <div class="max-w-md bg-white border border-slate-200 rounded-xl p-6">
        <p><strong><%= user.first_name %> <%= user.last_name %></strong> (<%= user.email %>)</p>
        <p class="mt-2">Current balance: <span class="font-bold">$<%= user.balance.toFixed(2) %></span></p>
        <form action="/admin/users/<%= user.id %>/update-balance" method="POST" class="mt-4">
          <input type="hidden" name="_csrf" value="<%= csrfToken %>">
          <div class="mb-4">
            <label class="block text-sm font-medium mb-1">New Balance ($)</label>
            <input type="number" name="new_balance" step="0.01" required class="w-full px-3 py-2 border border-slate-300 rounded">
          </div>
          <div class="mb-6">
            <label class="block text-sm font-medium mb-1">Reason (optional)</label>
            <input type="text" name="reason" class="w-full px-3 py-2 border border-slate-300 rounded">
          </div>
          <button type="submit" class="w-full bg-blue-600 text-white py-2 rounded">Update Balance</button>
        </form>
      </div>
    </main>
  </div>
</div>
<script> /* same profile dropdown script */ </script>
<%- include('../partials/footer') %>