<!DOCTYPE html>
<html lang="en">
<head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1.0"><title>Settings - XSpaceFinance</title><script src="https://cdn.tailwindcss.com"></script><link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet"></head>
<body class="bg-gradient-to-br from-slate-900 via-slate-800 to-slate-900 text-white">
  <%- include('../partials/admin-sidebar') %>
  <div class="lg:ml-72 min-h-screen">
    <div class="bg-slate-800/50 border-b border-slate-700 px-6 py-4"><h1 class="text-2xl font-bold bg-gradient-to-r from-white to-blue-400 bg-clip-text text-transparent">Site Settings</h1><p class="text-slate-400 text-sm">Configure global platform settings</p></div>
    <div class="p-6">
      <div class="bg-slate-800 rounded-xl border border-slate-700 p-6"><h2 class="text-lg font-bold mb-4">General Settings</h2><div class="grid md:grid-cols-2 gap-6"><div><label class="block text-sm font-medium mb-2">Site Name</label><input type="text" value="XSpaceFinance" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2"><label class="block text-sm font-medium mt-4 mb-2">Minimum Deposit ($)</label><input type="number" value="50" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2"><label class="block text-sm font-medium mt-4 mb-2">Minimum Withdrawal ($)</label><input type="number" value="100" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2"></div><div><label class="block text-sm font-medium mb-2">Referral Bonus (%)</label><input type="number" value="20" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2"><label class="block text-sm font-medium mt-4 mb-2">Support Email</label><input type="email" value="support@xspacefinance.com" class="w-full bg-slate-700 border border-slate-600 rounded-lg px-3 py-2"><label class="flex items-center gap-2 mt-4"><input type="checkbox" class="w-4 h-4"> Maintenance Mode</label></div></div><button class="mt-6 px-6 py-2 bg-blue-600 rounded-lg hover:bg-blue-700">Save Settings</button></div>
    </div>
  </div>
</body>
</html>